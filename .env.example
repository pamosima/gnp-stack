# Copy to .env and set for your deployment.
# Used by compose (e.g. HYPERDX_APP_URL) and as the canonical host for docs/scripts.

# Host where netops-stack runs (IP or hostname). Devices send syslog/gNMI/IPFIX here.
NETOPS_STACK_HOST=198.18.134.22

# Optional: base URL for HyperDX (no port; image appends :8080). Set when accessing by IP so redirects work.
# HYPERDX_APP_URL=http://198.18.134.22
