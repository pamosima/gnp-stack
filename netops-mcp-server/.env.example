# NetOps MCP Server — copy to .env and set values
# Only set the backends you use.

# Server
MCP_HOST=0.0.0.0
MCP_PORT=8010
# LOG_LEVEL=INFO (default). Set LOG_LEVEL=DEBUG to see GitLab trigger request/response in Docker logs.

# NetBox (optional)
# NETBOX_URL=https://netbox.example.com
# NETBOX_TOKEN=your-token
# NETBOX_VERIFY_SSL=true

# Prometheus (optional, netops-stack default)
# PROMETHEUS_URL=http://localhost:9090

# ClickHouse (optional, netops-stack default)
# CLICKHOUSE_URL=http://localhost:8123
# CLICKHOUSE_USER=
# CLICKHOUSE_PASSWORD=
# CLICKHOUSE_DATABASE=default

# GitLab (optional — for CI/CD and repo file updates)
# GITLAB_URL=https://gitlab.com
# GITLAB_TOKEN=glpat-...   # Project or personal access token (api scope); used for trigger, status, artifacts, repo files (POST projects/:id/pipeline with variables in JSON)
# GITLAB_DEFAULT_PROJECT_ID=12345
# GITLAB_ALLOWED_FILE_PATHS=ansible/,configs/,host_vars/,group_vars/,playbooks/,inventory/,roles/,vars/,templates/
# GITLAB_ALLOWED_VARIABLES= comma-separated; omit to allow all defaults. Must include COMPARE_ONLY,PIPELINE_TYPE,COLLECT_PIPELINE,ROLLBACK_PIPELINE,DRY_RUN_PIPELINE,TARGET_HOST,COMMIT_COLLECTED,COMMIT_DIFFS for pipeline triggers.

# IOS-XE (optional — for show/config on devices)
# IOS_XE_USERNAME=admin
# IOS_XE_PASSWORD=secret
# IOS_XE_READ_ONLY=false
